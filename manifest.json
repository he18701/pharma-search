<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#1a4a7a">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="薬品検索">
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="apple-touch-icon.png">
<title>薬品ロケーション検索</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{width:100%;height:100%;overflow:hidden}
body{font-family:-apple-system,BlinkMacSystemFont,'Helvetica Neue',sans-serif;background:#f0f2f5;color:#1a1a1a;display:flex;flex-direction:column}

/* header */
header{background:#1a4a7a;color:#fff;padding:12px 16px;flex-shrink:0;display:flex;align-items:center;justify-content:space-between}
header h1{font-size:16px;font-weight:600}
header p{font-size:11px;opacity:.65;margin-top:1px}
.install-btn{background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.4);color:#fff;border-radius:8px;padding:6px 12px;font-size:12px;cursor:pointer;display:none}

/* tabs */
.tab-nav{background:#1a4a7a;display:flex;flex-shrink:0;border-top:1px solid rgba(255,255,255,.15)}
.tab-btn{flex:1;background:none;border:none;color:rgba(255,255,255,.55);padding:8px 0 10px;font-size:12px;font-weight:500;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:2px;border-bottom:2.5px solid transparent}
.tab-btn .ti{font-size:19px;line-height:1}
.tab-btn.active{color:#fff;border-bottom-color:#fff}

/* panels */
.panel{display:none;flex-direction:column;flex:1;overflow:hidden}
.panel.active{display:flex}

/* search */
.search-wrap{background:#fff;border-bottom:1px solid #dde2ea;padding:10px 12px 0;flex-shrink:0}
.search-box{position:relative;margin-bottom:8px}
.search-box input{width:100%;padding:10px 40px 10px 14px;border:1.5px solid #c8d0dc;border-radius:10px;font-size:16px;outline:none;background:#fafbfc}
.search-box input:focus{border-color:#1a4a7a;background:#fff}
.search-box .clr{position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;font-size:17px;color:#aaa;cursor:pointer;display:none;padding:3px}
.filter-row{display:flex;gap:6px;margin-bottom:8px}
select{flex:1;padding:8px 6px;border:1.5px solid #c8d0dc;border-radius:10px;font-size:13px;background:#fafbfc;color:#333;outline:none}
.status{font-size:12px;color:#778;padding-bottom:6px}

/* suggest */
.suggest{position:absolute;top:calc(100% + 4px);left:0;right:0;background:#fff;border:1px solid #c8d0dc;border-radius:12px;box-shadow:0 6px 24px rgba(0,0,0,.13);max-height:50vh;overflow-y:auto;z-index:200;display:none}
.suggest.open{display:block}
.si{display:flex;align-items:center;padding:10px 12px;gap:10px;cursor:pointer;border-bottom:1px solid #f0f2f5}
.si:last-child{border-bottom:none}
.si:hover,.si.active{background:#eef4ff}
.si-loc{background:#1a4a7a;color:#fff;border-radius:7px;padding:4px 9px;font-size:13px;font-weight:700;white-space:nowrap;min-width:52px;text-align:center}
.si-name{flex:1;font-size:14px;line-height:1.35}
.si-name em{font-style:normal;color:#1a4a7a;font-weight:700}
.t2b{font-size:11px;font-weight:700;padding:2px 6px;border-radius:4px;white-space:nowrap}
.t2-覚{background:#ffeaea;color:#b00}
.t2-毒{background:#fff3cd;color:#7a4f00}
.t2-向,.t2-向GE{background:#e8f0ff;color:#1a3a8f}
.smore{padding:9px 12px;font-size:12px;color:#778;text-align:center;border-top:1px solid #eee}

/* results */
.res-scroll{flex:1;overflow-y:auto;padding:10px 12px 40px}
.rcard{background:#fff;border-radius:12px;box-shadow:0 1px 4px rgba(0,0,0,.07);overflow:hidden;margin-bottom:12px}
.rhead{background:#eef2f8;padding:7px 12px;font-size:12px;font-weight:600;color:#556;border-bottom:1px solid #dde2ea}
table{width:100%;border-collapse:collapse}
thead th{padding:7px 10px;text-align:left;font-size:11px;font-weight:600;color:#778;border-bottom:1px solid #eee}
tbody tr{border-bottom:1px solid #f3f4f6}
tbody tr:last-child{border-bottom:none}
td{padding:9px 10px;font-size:13px;vertical-align:middle}
.lb{display:inline-block;background:#1a4a7a;color:#fff;border-radius:6px;padding:3px 8px;font-size:12px;font-weight:700}
.drug em{font-style:normal;font-weight:700;color:#1a4a7a}
.code{font-family:monospace;font-size:11px;color:#aaa}
.hint{text-align:center;padding:40px 20px;color:#bbc;font-size:14px}
.empty{text-align:center;padding:40px 20px;color:#aab;font-size:14px}

/* camera panel */
.cam-panel{display:none;flex-direction:column;flex:1;overflow:hidden;background:#000}
.cam-panel.active{display:flex}
.cam-view{position:relative;flex:1;overflow:hidden;display:flex;align-items:center;justify-content:center}
#camVideo{width:100%;height:100%;object-fit:cover;display:block}
.scan-ov{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none}
.scan-win{width:min(75vw,320px);height:130px;border:2px solid rgba(255,255,255,.8);border-radius:10px;position:relative;box-shadow:0 0 0 9999px rgba(0,0,0,.5)}
.scan-line{position:absolute;left:4px;right:4px;height:2px;background:#4af;animation:sc 1.8s ease-in-out infinite;box-shadow:0 0 6px #4af}
@keyframes sc{0%,100%{top:8px}50%{top:calc(100% - 10px)}}
.flash{position:absolute;inset:0;background:#fff;opacity:0;pointer-events:none;transition:opacity .05s}
.flash.on{opacity:.7}
.cam-status{color:rgba(255,255,255,.85);font-size:13px;text-align:center;padding:8px 16px;flex-shrink:0}
.cam-result{background:#fff;padding:12px 14px;flex-shrink:0;min-height:72px}
.cr-empty{color:#778;font-size:13px;text-align:center;padding:6px 0}
.cr-row{display:flex;align-items:center;gap:10px;padding:9px 10px;background:#eef4ff;border-radius:9px;border-left:4px solid #1a4a7a;margin-bottom:6px}
.cr-name{flex:1;font-size:14px;font-weight:500}
.cr-raw{font-size:11px;color:#aaa;font-family:monospace;text-align:center;margin-top:4px}
.cr-ng{color:#c33;font-size:13px;text-align:center;padding:6px 0}
.torch-btn{position:absolute;bottom:10px;right:10px;background:rgba(0,0,0,.5);border:1px solid rgba(255,255,255,.3);color:#fff;border-radius:50%;width:42px;height:42px;font-size:18px;cursor:pointer;display:none;align-items:center;justify-content:center}
</style>
</head>
<body>

<header>
  <div>
    <h1>&#128138; 薬品ロケーション検索</h1>
    <p>全2099品目 / オフライン対応</p>
  </div>
  <button class="install-btn" id="installBtn">&#128242; 追加</button>
</header>

<nav class="tab-nav">
  <button class="tab-btn active" id="tabText" onclick="switchTab('text')">
    <span class="ti">&#128290;</span>文字検索
  </button>
  <button class="tab-btn" id="tabCam" onclick="switchTab('cam')">
    <span class="ti">&#128247;</span>カメラ
  </button>
</nav>

<!-- 文字検索 -->
<div class="panel active" id="panelText">
  <div class="search-wrap">
    <div class="search-box">
      <input type="text" id="si" placeholder="薬品名・バーコード・棚番号 (例: A-1)" autocomplete="off" spellcheck="false" inputmode="search">
      <button class="clr" id="clrBtn" onclick="clrSearch()">&#10005;</button>
      <div class="suggest" id="sbox"></div>
    </div>
    <div class="filter-row">
      <select id="af" onchange="renderTable()"><option value="">全エリア</option></select>
      <select id="tf" onchange="renderTable()">
        <option value="">全分類</option>
        <option value="覚">覚醒剤</option>
        <option value="毒">毒薬</option>
        <option value="向">向精神薬</option>
        <option value="向GE">向GE</option>
      </select>
    </div>
    <div class="status" id="stl">薬品名・バーコード・棚番号で検索できます</div>
  </div>
  <div class="res-scroll" id="ra">
    <div class="hint">&#128269; 薬品名を入力してください</div>
  </div>
</div>

<!-- カメラ -->
<div class="cam-panel" id="panelCam">
  <div class="cam-view">
    <video id="camVideo" autoplay playsinline muted></video>
    <div class="scan-ov"><div class="scan-win"><div class="scan-line"></div></div></div>
    <div class="flash" id="fl"></div>
    <button class="torch-btn" id="torchBtn" onclick="toggleTorch()">&#128161;</button>
  </div>
  <div class="cam-status" id="cst">カメラを起動中...</div>
  <div class="cam-result" id="cr"><div class="cr-empty">スキャン待機中</div></div>
</div>

<script src="https://unpkg.com/@zxing/library@0.19.3/umd/index.min.js"></script>

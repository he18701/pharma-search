function norm(s){
  if(!s)return'';
  return s.toString().replace(/[Ａ-Ｚａ-ｚ０-９]/g,c=>String.fromCharCode(c.charCodeAt(0)-0xFEE0)).replace(/[ぁ-ん]/g,c=>String.fromCharCode(c.charCodeAt(0)+0x60)).toLowerCase();
}
function esc(s){return s?s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'):''}
function loc(d){return d.a+'-'+d.t}
function t2b(t){return t?`<span class="t2b t2-${esc(t)}">${esc(t)}</span>`:''}
function hl(text,q){
  const s=esc(text);if(!q)return s;
  const nt=norm(text),nq=norm(q.trim());if(!nq)return s;
  const i=nt.indexOf(nq);if(i<0)return s;
  return s.slice(0,i)+'<em>'+s.slice(i,i+q.trim().length)+'</em>'+s.slice(i+q.trim().length);
}
function filter(q,area,tag2){
  const nq=norm(q);
  return DATA.filter(d=>{
    if(area&&d.a!==area)return false;
    if(tag2&&d.t2!==tag2)return false;
    if(!nq)return true;
    return norm(d.n).includes(nq)||norm(d.c).includes(nq)||norm(loc(d)).includes(nq);
  });
}

// タブ
let camStarted=false,camPaused=false;
function switchTab(t){
  document.getElementById('tabText').classList.toggle('active',t==='text');
  document.getElementById('tabCam').classList.toggle('active',t==='cam');
  document.getElementById('panelText').classList.toggle('active',t==='text');
  document.getElementById('panelCam').classList.toggle('active',t==='cam');
  if(t==='cam'){
    if(!camStarted){startCamera();camStarted=true;}
    else resumeCam();
  } else {
    pauseCam();
  }
}

// 文字検索
let cq='',sits=[],sidx=-1,sopen=false;
const sinput=document.getElementById('si'),sbox=document.getElementById('sbox'),clrBtn=document.getElementById('clrBtn');

sinput.addEventListener('input',()=>{
  cq=sinput.value;clrBtn.style.display=cq?'block':'none';sidx=-1;
  if(cq.trim())showSuggest();else{closeSuggest();renderTable();}
});
sinput.addEventListener('keydown',e=>{
  if(!sopen)return;
  if(e.key==='ArrowDown'){e.preventDefault();sidx=Math.min(sidx+1,sits.length-1);updAct();}
  else if(e.key==='ArrowUp'){e.preventDefault();sidx=Math.max(sidx-1,-1);updAct();}
  else if(e.key==='Enter'){e.preventDefault();if(sidx>=0&&sits[sidx])selSuggest(sits[sidx]);else{closeSuggest();renderTable();}}
  else if(e.key==='Escape')closeSuggest();
});
document.addEventListener('click',e=>{if(!sbox.contains(e.target)&&e.target!==sinput)closeSuggest();});

function showSuggest(){
  const area=document.getElementById('af').value,tag2=document.getElementById('tf').value;
  const res=filter(cq,area,tag2);sits=res;
  if(!res.length){sbox.innerHTML='<div class="smore">該当なし</div>';sbox.classList.add('open');sopen=true;renderTable();return;}
  let html='';
  res.slice(0,60).forEach((d,i)=>{
    html+=`<div class="si" data-i="${i}" onmousedown="selSuggest(sits[${i}])" onmouseover="sidx=${i};updAct()">
      <span class="si-loc">${esc(d.a)}-${esc(d.t)}</span>
      <span class="si-name">${hl(d.n,cq)}</span>${t2b(d.t2)}</div>`;
  });
  if(res.length>60)html+=`<div class="smore">他 ${res.length-60} 件</div>`;
  sbox.innerHTML=html;sbox.classList.add('open');sopen=true;renderTable();
}
function updAct(){
  sbox.querySelectorAll('.si').forEach((el,i)=>el.classList.toggle('active',i===sidx));
  const el=sbox.querySelectorAll('.si')[sidx];if(el)el.scrollIntoView({block:'nearest'});
}
function selSuggest(d){sinput.value=d.n;cq=d.n;clrBtn.style.display='block';closeSuggest();renderTable();}
function closeSuggest(){sbox.classList.remove('open');sopen=false;}
function clrSearch(){sinput.value='';cq='';clrBtn.style.display='none';closeSuggest();renderTable();sinput.focus();}

function renderTable(){
  const area=document.getElementById('af').value,tag2=document.getElementById('tf').value;
  const res=filter(cq,area,tag2);
  const el=document.getElementById('ra'),st=document.getElementById('stl');
  if(!cq.trim()&&!area&&!tag2){el.innerHTML='<div class="hint">&#128269; 薬品名を入力してください</div>';st.textContent='薬品名・バーコード・棚番号で検索できます';return;}
  st.textContent=res.length+' 件ヒット';
  if(!res.length){el.innerHTML='<div class="empty">&#129300; 該当する薬品が見つかりませんでした</div>';return;}
  const grp={};
  res.forEach(d=>{if(!grp[d.a])grp[d.a]=[];grp[d.a].push(d);});
  const sA=Object.keys(grp).sort((a,b)=>(AO.indexOf(a)<0?99:AO.indexOf(a))-(AO.indexOf(b)<0?99:AO.indexOf(b)));
  let html='';
  sA.forEach(ar=>{
    const ds=grp[ar];
    html+=`<div class="rcard"><div class="rhead">エリア ${esc(ar)} — ${ds.length}件</div>
      <table><thead><tr><th>棚番号</th><th>薬品名</th><th>バーコード</th></tr></thead><tbody>`;
    ds.slice(0,300).forEach(d=>{
      html+=`<tr><td><span class="lb">${esc(d.a)}-${esc(d.t)}</span>${d.t2?' '+t2b(d.t2):''}</td>
        <td class="drug">${hl(d.n,cq)}</td><td class="code">${esc(d.c)}</td></tr>`;
    });
    html+=`</tbody></table></div>`;
  });
  el.innerHTML=html;
}

// カメラ
let codeReader=null,vtrack=null,torchOn=false;

async function startCamera(){
  const cst=document.getElementById('cst');
  try{
    if(typeof ZXing==='undefined'){cst.textContent='ライブラリ読み込み中...';await new Promise(r=>setTimeout(r,2000));}
    if(typeof ZXing==='undefined'){cst.textContent='⚠️ ライブラリ読み込み失敗。ネット接続を確認してください。';return;}
    const hints=new Map();
    hints.set(ZXing.DecodeHintType.POSSIBLE_FORMATS,[
      ZXing.BarcodeFormat.EAN_13,ZXing.BarcodeFormat.EAN_8,
      ZXing.BarcodeFormat.CODE_128,ZXing.BarcodeFormat.CODE_39,
      ZXing.BarcodeFormat.ITF,ZXing.BarcodeFormat.QR_CODE,
    ]);
    hints.set(ZXing.DecodeHintType.TRY_HARDER,true);
    codeReader=new ZXing.BrowserMultiFormatReader(hints,200);
    const devs=await ZXing.BrowserCodeReader.listVideoInputDevices();
    const dev=devs.find(d=>/back|rear|environment/i.test(d.label))||devs[devs.length-1]||devs[0];
    cst.textContent='バーコードをフレーム内に合わせてください';
    await codeReader.decodeFromVideoDevice(dev?.deviceId,'camVideo',(result)=>{
      if(result&&!camPaused)onScanned(result.getText());
    });
    const vid=document.getElementById('camVideo');
    if(vid.srcObject){
      vtrack=vid.srcObject.getVideoTracks()[0];
      const caps=vtrack.getCapabilities?.();
      const tb=document.getElementById('torchBtn');
      if(caps&&caps.torch)tb.style.display='flex';
    }
  }catch(err){
    document.getElementById('cst').textContent='⚠️ カメラを起動できませんでした: '+(err.message||err);
  }
}
function pauseCam(){
  camPaused=true;
  const v=document.getElementById('camVideo');
  if(v.srcObject)v.srcObject.getVideoTracks().forEach(t=>t.enabled=false);
}
function resumeCam(){
  camPaused=false;
  const v=document.getElementById('camVideo');
  if(v.srcObject)v.srcObject.getVideoTracks().forEach(t=>t.enabled=true);
  else if(!codeReader)startCamera();
}
async function toggleTorch(){
  if(!vtrack)return;torchOn=!torchOn;
  try{await vtrack.applyConstraints({advanced:[{torch:torchOn}]});}
  catch(e){torchOn=!torchOn;}
  document.getElementById('torchBtn').style.opacity=torchOn?'1':'0.5';
}

let lastCode='',lastTime=0;
function onScanned(code){
  const now=Date.now();
  if(code===lastCode&&now-lastTime<1500)return;
  lastCode=code;lastTime=now;
  const fl=document.getElementById('fl');
  fl.classList.add('on');setTimeout(()=>fl.classList.remove('on'),120);
  if(navigator.vibrate)navigator.vibrate(60);
  document.getElementById('cst').textContent='読取: '+code;
  showCamResult(code);
}
function showCamResult(code){
  const panel=document.getElementById('cr');
  const nCode=norm(code);
  const hits=DATA.filter(d=>{
    const nc=norm(d.c);
    return nc===nCode||nc===nCode.replace(/^1/,'')||nCode===nc.replace(/^1/,'');
  });
  if(!hits.length){
    panel.innerHTML=`<div class="cr-ng">&#9888;&#65039; 登録されていないバーコードです</div><div class="cr-raw">${esc(code)}</div>`;
    return;
  }
  let rows='';
  hits.forEach(d=>{
    rows+=`<div class="cr-row"><span class="lb">${esc(d.a)}-${esc(d.t)}</span><span class="cr-name">${esc(d.n)}</span>${t2b(d.t2)}</div>`;
  });
  panel.innerHTML=rows+`<div class="cr-raw">${esc(code)}</div>`;
}

// PWA
let dp=null;
window.addEventListener('beforeinstallprompt',e=>{e.preventDefault();dp=e;document.getElementById('installBtn').style.display='block';});
document.getElementById('installBtn').addEventListener('click',async()=>{if(!dp)return;dp.prompt();const{outcome}=await dp.userChoice;dp=null;if(outcome==='accepted')document.getElementById('installBtn').style.display='none';});

if('serviceWorker' in navigator)navigator.serviceWorker.register('./sw.js');
</script>
